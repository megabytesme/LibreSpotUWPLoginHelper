<Window
    x:Class="LibreSpotUWPLoginHelper.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    Title="LibreSpotUWP Login Helper">
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:TitleBar
            x:Name="HelperTitleBar"
            Title="LibreSpotUWP Login Helper"
            Background="Transparent"
            HorizontalAlignment="Stretch">
            <controls:TitleBar.IconSource>
                <BitmapIconSource ShowAsMonochrome="False" UriSource="ms-appx:///Assets/LibreSpotUWP.png" />
            </controls:TitleBar.IconSource>
        </controls:TitleBar>

        <Grid Grid.Row="1">
            <Grid
                x:Name="PageHost"
                Background="Transparent">
                <Grid
                    x:Name="WelcomePage"
                    Visibility="Visible">
                    <Border
                        MaxWidth="580"
                        Margin="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="16">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Margin="36,36,36,0"
                                FontSize="32"
                                FontWeight="SemiBold"
                                Text="Welcome to LibreSpotUWP Login Helper"
                                TextWrapping="Wrap" />

                            <ScrollViewer
                                Grid.Row="1"
                                Padding="36,12,36,0"
                                VerticalScrollBarVisibility="Auto"
                                VerticalScrollMode="Auto">
                                <StackPanel Spacing="0">
                                    <TextBlock
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="This is an app which generates a QR code for easy sign in on LibreSpotUWP, meant for older Windows devices."
                                        TextWrapping="Wrap" />

                                    <StackPanel Margin="0,16,0,0" Spacing="8">
                                        <TextBlock
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="Note: This app is only able to generate a QR Code for logging in. If you are looking for the LibreSpotUWP app, you can find it here:"
                                            TextWrapping="Wrap" />
                                        <HyperlinkButton
                                            x:Name="ProjectLinkButton"
                                            HorizontalAlignment="Left"
                                            Click="ProjectLinkButton_Click"
                                            Content="megabytesme/LibreSpotUWP" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <Grid Grid.Row="2" Margin="36,24,36,36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    Grid.Column="1"
                                    Click="NextButton_Click"
                                    Content="Next" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid
                    x:Name="SpotifyLoginPage"
                    Visibility="Collapsed">
                    <Border
                        MaxWidth="580"
                        Margin="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="16">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Margin="36,36,36,0"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Text="Login to Spotify"
                                TextWrapping="Wrap" />

                            <ScrollViewer
                                Grid.Row="1"
                                Padding="36,12,36,0"
                                VerticalScrollBarVisibility="Auto"
                                VerticalScrollMode="Auto">
                                <StackPanel Spacing="0">
                                    <TextBlock
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="To continue, press &quot;Login with Spotify&quot;. This will grant the app the ability to generate a QR code to scan on your device."
                                        TextWrapping="Wrap" />

                                    <TextBox
                                        x:Name="SpotifyCustomClientIdTextBox"
                                        Margin="0,20,0,0"
                                        Header="Custom Spotify Client ID"
                                        MaxLength="64"
                                        PlaceholderText="Optional, advanced users only"
                                        TextChanged="SpotifyCustomClientIdTextBox_TextChanged" />

                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Optional and recommended only for advanced users. If you use a custom Spotify app/client ID, enter it here before logging in and configure its redirect URI as http://127.0.0.1:8898/login. Leave empty to use the default helper client ID."
                                        TextWrapping="WrapWholeWords" />

                                    <controls:InfoBar
                                        x:Name="LoginStatusInfoBar"
                                        Margin="0,20,0,0"
                                        IsClosable="False"
                                        IsOpen="True"
                                        Severity="Informational"
                                        Title="Status"
                                        Message="Waiting for Spotify sign-in." />
                                </StackPanel>
                            </ScrollViewer>

                            <Grid Grid.Row="2" Margin="36,24,36,36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    Grid.Column="0"
                                    HorizontalAlignment="Left"
                                    Click="BackButton_Click"
                                    Content="Back" />

                                <Button
                                    x:Name="LoginButton"
                                    Grid.Column="2"
                                    Margin="0,0,12,0"
                                    Click="LoginButton_Click"
                                    Content="Login with Spotify" />

                                <Button
                                    x:Name="LoginNextButton"
                                    Grid.Column="3"
                                    Click="NextButton_Click"
                                    Content="Next"
                                    IsEnabled="False" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid
                    x:Name="QrLoginPage"
                    Visibility="Collapsed">
                    <Border
                        MaxWidth="760"
                        Margin="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="16">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Margin="36,36,36,0"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Text="Login with LibreSpotUWP"
                                TextWrapping="Wrap" />

                            <ScrollViewer
                                Grid.Row="1"
                                Padding="36,12,36,0"
                                VerticalScrollBarVisibility="Auto"
                                VerticalScrollMode="Auto">
                                <StackPanel Spacing="0">
                                    <TextBlock
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="On your device, open LibreSpotUWP and then do the following:"
                                        TextWrapping="Wrap" />

                                    <StackPanel Margin="0,12,0,0" Spacing="8">
                                        <TextBlock Style="{StaticResource BodyTextStyle}" Text="1: Open the Settings page" TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource BodyTextStyle}" Text="2: Press &quot;Log In&quot; at the top of the page" TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource BodyTextStyle}" Text="3: Press &quot;Sign in with QR Code&quot;" TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource BodyTextStyle}" Text="4: Aim the camera at the QR Code below:" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Margin="0,24,0,0" HorizontalAlignment="Center" Spacing="10">
                                        <Button
                                            x:Name="QrButton"
                                            Width="320"
                                            Height="320"
                                            Padding="0"
                                            Click="QrButton_Click"
                                            HorizontalAlignment="Center">
                                            <Grid>
                                                <Border
                                                    Background="White"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12" />
                                                <Image
                                                    x:Name="QrCodeImage"
                                                    Margin="18"
                                                    Stretch="Uniform" />
                                            </Grid>
                                        </Button>

                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="Press the QR Code if it is too small"
                                            TextWrapping="Wrap" />

                                        <Button
                                            x:Name="ExportTextButton"
                                            HorizontalAlignment="Center"
                                            Click="ExportTextButton_Click"
                                            Content="Export sign-in details as text" />

                                        <TextBlock
                                            MaxWidth="560"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="Warning: Do not share the generated QR Code or sign-in details text with anyone! Only use them with your own LibreSpotUWP devices."
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <Grid Grid.Row="2" Margin="36,24,36,36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    Grid.Column="1"
                                    Click="ExitButton_Click"
                                    Content="Exit" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid
                x:Name="QrOverlay"
                Background="#99000000"
                Visibility="Collapsed">
                <Border
                    x:Name="QrOverlayHost"
                    Width="900"
                    Height="900"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    CornerRadius="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Button
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="16"
                            Click="CloseQrOverlayButton_Click"
                            AutomationProperties.Name="Close QR preview">
                            <SymbolIcon Symbol="Cancel" />
                        </Button>

                        <Viewbox Grid.Row="1" Margin="24" Stretch="Uniform">
                            <Border
                                Background="White"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="24">
                                <Image
                                    x:Name="QrOverlayImage"
                                    Width="720"
                                    Height="720"
                                    Stretch="Uniform" />
                            </Border>
                        </Viewbox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
